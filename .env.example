# ZhipuAI (GLM-5) API key
ZAI_API_KEY=your-zhipuai-api-key

# Search tool API key (Tavily)
TAVILY_API_KEY=your-tavily-api-key

# Google Calendar service account JSON (full JSON string)
GOOGLE_CALENDAR_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# Google Calendar ID to use (default: "primary")
GOOGLE_CALENDAR_ID=primary

# Optional: LangSmith tracing
# LANGSMITH_TRACING=true
# LANGSMITH_API_KEY=your-langsmith-api-key
